# E-Masjid Backend — Environment Variables (template — no real secrets)
# Copy this file to `.env` and fill in real values.
# See README.md for setup instructions.

# ─── Server ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ─────────────────────────────────────────────────────────
# Local: mongodb://127.0.0.1:27017/emasjid
# Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/emasjid
MONGODB_URI=mongodb+srv://user:password@cluster.example.net/emasjid?retryWrites=true&w=majority

# ─── Auth (JWT) ────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRE=8h

# ─── Frontend URL (CORS + email reset links) ──────────────────────────
CLIENT_URL=http://localhost:5173

# ─── Stripe (Test Mode) ───────────────────────────────────────────────
# Get test keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email — SendGrid (primary) ────────────────────────────────────────
# 1. Sign up at https://signup.sendgrid.com (free, 100 emails/day forever)
# 2. Create an API key at https://app.sendgrid.com/settings/api_keys
#    - Name: "E-Masjid"
#    - Permission: Restricted Access → Mail Send = ON, everything else OFF
# 3. Verify your sender at https://app.sendgrid.com/settings/senders
#    - From email must match SENDGRID_FROM_EMAIL below
#    - SendGrid sends a verification email — click the link
SENDGRID_API_KEY=SG.your_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=E-Masjid System

# ─── Email — SMTP fallback (only used if SENDGRID_API_KEY is empty) ───
# Use Mailtrap for dev sandbox testing, or any SMTP relay.
# Sign up at https://mailtrap.io (free sandbox tier).
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_mailtrap_user
EMAIL_PASS=your_mailtrap_pass
EMAIL_FROM=noreply@yourdomain.com

# Provider override (optional — auto-detected by default):
#   "sendgrid" → force SendGrid
#   "smtp"     → force SMTP/Mailtrap
# Leave empty to auto-detect (SendGrid if SENDGRID_API_KEY is set, else SMTP).
EMAIL_PROVIDER=
